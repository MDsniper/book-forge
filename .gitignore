# book-forge .gitignore

# Dependencies
node_modules/

# OS / editor cruft
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# Project-local book files (a skill consumer might run the installer inside
# their own book folder — never commit those books to the skill repo).
# IMPORTANT: only match these at the repo ROOT, so the templates under
# assets/templates/ stay tracked. The leading slash anchors to root.
book-forge-test/
/*.epub
/*.docx
/*.pdf
/manuscript.md
/book.md
/chapters/
/state.json
/project.yaml
/seed.txt
/publish/
/exports/
/images/
/briefs/
/eval_logs/
/edit_logs/
/results.tsv
/arc_summary.md
/outline.md.bak

# Local config with real API keys (NEVER commit)
.book-forge/
image-config.json

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
.pytest_cache/
.mypy_cache/
